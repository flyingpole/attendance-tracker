rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teams, players, and session types are read by the public kiosk page
    // (to resolve a scanned badge instantly) but only written by the
    // logged-in director/admin account.
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Master schedule (day/time rules the kiosk uses to auto-detect which
    // practice a scan belongs to) — same public-read/admin-write pattern.
    match /schedule/{scheduleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Per-occurrence cancellations for a recurring schedule entry (e.g. one
    // Tuesday is skipped for a holiday, without ending the whole series).
    match /scheduleCancellations/{cancellationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Attendance scans are created by the unauthenticated kiosk. Reading them
    // back requires the logged-in director/admin account (so the admin
    // console can show who attended a past practice) — a public, logged-out
    // visitor to the kiosk URL still can't read attendance history. Records
    // are otherwise immutable: no client-side edits or deletes.
    match /attendance/{recordId} {
      allow create: if request.resource.data.keys().hasAll(
                        ['playerId', 'playerName', 'teamId', 'sessionId', 'sessionLabel', 'timestamp']
                      )
                      && request.resource.data.playerId is string
                      && request.resource.data.timestamp == request.time;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
